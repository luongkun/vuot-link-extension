{
  "manifest_version": 3,
  "name": "Vượt Link - Auto Link Bypasser",
  "short_name": "Vượt Link",
  "version": "0.2.0",
  "description": "Tự động vượt qua các trang rút gọn link / quảng cáo (Linkvertise, ouo.io, link1s, yeumoney, bit.ly, t.co, v.v.) bằng API Crowd-Bypass / bypass.vip.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Vượt Link",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "webNavigation",
    "tabs",
    "alarms",
    "notifications",
    "contextMenus"
  ],
  "host_permissions": [
    "https://crowd.fastforward.team/*",
    "https://api.bypass.vip/*",
    "https://api.bypass.city/*",
    "https://bypass.city/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://link1s.com/*",
        "*://*.link1s.com/*",
        "*://link1s.net/*",
        "*://*.link1s.net/*",
        "*://link4m.com/*",
        "*://*.link4m.com/*",
        "*://yeumoney.com/*",
        "*://*.yeumoney.com/*",
        "*://yeumoney.net/*",
        "*://*.yeumoney.net/*",
        "*://kiemtienol.com/*",
        "*://*.kiemtienol.com/*",
        "*://kiemtienmod.net/*",
        "*://*.kiemtienmod.net/*",
        "*://kiemtien.gg/*",
        "*://*.kiemtien.gg/*",
        "*://kiemtienbank.com/*",
        "*://*.kiemtienbank.com/*",
        "*://megaurl.in/*",
        "*://*.megaurl.in/*",
        "*://ouo.io/*",
        "*://*.ouo.io/*",
        "*://ouo.press/*",
        "*://*.ouo.press/*",
        "*://shorte.st/*",
        "*://*.shorte.st/*",
        "*://sh.st/*",
        "*://*.sh.st/*",
        "*://adf.ly/*",
        "*://*.adf.ly/*",
        "*://adfoc.us/*",
        "*://*.adfoc.us/*",
        "*://exe.io/*",
        "*://*.exe.io/*",
        "*://exey.io/*",
        "*://*.exey.io/*",
        "*://exee.io/*",
        "*://*.exee.io/*",
        "*://exee.app/*",
        "*://*.exee.app/*",
        "*://owolinks.com/*",
        "*://*.owolinks.com/*",
        "*://droplink.co/*",
        "*://*.droplink.co/*",
        "*://cuty.io/*",
        "*://*.cuty.io/*",
        "*://cety.io/*",
        "*://*.cety.io/*",
        "*://boost.ink/*",
        "*://*.boost.ink/*",
        "*://loot-link.com/*",
        "*://*.loot-link.com/*",
        "*://lootdest.com/*",
        "*://*.lootdest.com/*",
        "*://lootdest.org/*",
        "*://*.lootdest.org/*",
        "*://lootdest.info/*",
        "*://*.lootdest.info/*",
        "*://lootlabs.gg/*",
        "*://*.lootlabs.gg/*",
        "*://paster.so/*",
        "*://*.paster.so/*",
        "*://paster.gg/*",
        "*://*.paster.gg/*",
        "*://social-unlock.com/*",
        "*://*.social-unlock.com/*",
        "*://sub2unlock.com/*",
        "*://*.sub2unlock.com/*",
        "*://sub2unlock.net/*",
        "*://*.sub2unlock.net/*",
        "*://sub4unlock.io/*",
        "*://*.sub4unlock.io/*",
        "*://rekonise.com/*",
        "*://*.rekonise.com/*",
        "*://mboost.me/*",
        "*://*.mboost.me/*",
        "*://linkvertise.com/*",
        "*://*.linkvertise.com/*",
        "*://linkvertise.net/*",
        "*://*.linkvertise.net/*",
        "*://link-to.net/*",
        "*://*.link-to.net/*",
        "*://work.ink/*",
        "*://*.work.ink/*"
      ],
      "js": ["content/redirect.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
